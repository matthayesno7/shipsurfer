# ── ShipSurfer license server ──────────────────────────────────────────────
# Railway sets PORT automatically; leave unset in production.
PORT=8787

# Your public base URL — used to build Stripe success/cancel links back to this
# server's own pages. In production set to your real domain.
PUBLIC_URL=https://api.shipsurfer.app

# ── Payments (real Stripe) ──────────────────────────────────────────────────
# Use TEST keys to try it end-to-end with card 4242 4242 4242 4242 (no real
# charge). Create a one-time $99 Price in the Stripe dashboard and paste its ID.
# To let testers pay $0, create a 100%-off promotion code in Stripe — the
# checkout already shows a promo-code field.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
# Optional: set if you configure a Stripe webhook (not required — the success
# page verifies the session directly).
STRIPE_WEBHOOK_SECRET=

# ── Beta shortcuts (leave OFF when using Stripe) ────────────────────────────
# FREE_BETA=true mints real keys with no payment at all. SIMULATE is a local
# dev flag. Keep both false to use the real Stripe flow above.
FREE_BETA=false
SIMULATE=false

# Persist issued keys on a mounted volume so redeploys don't wipe them.
# On Railway: add a Volume mounted at /data, then set:
LICENSE_STORE=/data/licenses.json
