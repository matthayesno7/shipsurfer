# ── Shipyard v0.1 configuration ────────────────────────────────────────────
# Copy to .env and fill in. See SETUP.md for how to obtain each value.

# Server
PORT=4000
BASE_URL=http://localhost:4000

# Encryption key for the local token store (32+ random chars).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHIPYARD_SECRET=

# ── GitHub App (for repo creation + push on behalf of the user) ─────────────
# Create at https://github.com/settings/apps  (see SETUP.md)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Paste the App private key as a single line with \n for newlines, or set
# GITHUB_PRIVATE_KEY_PATH to a .pem file path instead.
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=

# ── Railway OAuth app (Login with Railway) ─────────────────────────────────
# Create at Railway > Workspace Settings > Developer > New OAuth App
RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=

# ── Supabase OAuth app (v0.2 — database provisioning) ──────────────────────
# Create at Supabase > Organization settings > OAuth Apps
SUPABASE_CLIENT_ID=
SUPABASE_CLIENT_SECRET=

# ── Cloudflare Registrar — Shipyard's OWN account (reseller model) ─────────
# NOT a per-user setting. This is YOUR (the operator's) Cloudflare account that
# buys domains on behalf of users. Needs: Registrar API access (beta), a token
# with Registrar write perms, a billing profile, and a default registrant
# contact. Users never see or connect Cloudflare.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# ShipSurfer's own domain for free branded subdomains (Tier 1: <app>.shipsurfer.app).
# Must be registered in / managed by the Cloudflare account above.
SHIPSURFER_DOMAIN=shipsurfer.app

# ── Dev / demo ─────────────────────────────────────────────────────────────
# When true, the provisioning engine simulates every external call so you can
# watch the full state machine run with no credentials and no real resources.
DRY_RUN=true
