# ── ShipSurfer (local app) ──────────────────────────────────────────────────
# Good news: there's nothing secret to add here. ShipSurfer connects your
# GitHub / Railway / Supabase accounts through the hosted ShipSurfer broker, so
# no client secrets ever live on your machine. The encryption key for your local
# token store is generated automatically on first run.

# Set to false to do real deploys (true = safe dry-run that touches nothing).
DRY_RUN=false

# Where the app runs locally. Leave as-is.
PORT=4001
BASE_URL=http://localhost:4001

# Advanced / self-hosting only — leave unset to use the hosted ShipSurfer
# broker + license server at api.shipsurfer.app:
# SHIPSURFER_BROKER_URL=https://api.shipsurfer.app
# SHIPYARD_LICENSE_URL=https://api.shipsurfer.app
